    "K_all = structure.stacked_stiffness_matrices()                                                                      # Stacked stiffness matrix (6N x 6)\n",
    "\n",
    "# --- Convert to DataFrame for visualization -----------------------------------------------------------------------\n",
    "n_elem = len(structure.elements)\n",
    "n_dof  = local_dof\n",
